<?xml version="1.0"?>
<Container version="2">
  <Name>SnapSort</Name>
  <Repository>rediwed/snapsort:latest</Repository>
  <Registry>https://hub.docker.com/r/rediwed/snapsort/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/Rediwed/SnapSort</Project>
  <Overview>
    SnapSort automatically organizes your photos by EXIF date into
    Year/Month folders, detects duplicates via fast hashing, and filters
    out low-quality images. Dark-themed web UI for managing jobs,
    browsing results, and running storage benchmarks.
  </Overview>
  <Category>MediaApp:Photos</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/Rediwed/SnapSort/main/frontend/public/icon.png</Icon>
  <ExtraParams>--mount type=bind,source=/mnt/disks,target=/mnt/disks,bind-propagation=rslave --mount type=bind,source=/mnt/remotes,target=/mnt/remotes,bind-propagation=rslave</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>

  <!-- Web UI port -->
  <Config
    Name="WebUI Port"
    Target="4000"
    Default="8080"
    Mode="tcp"
    Description="Port for the SnapSort web interface"
    Type="Port"
    Display="always"
    Required="true"
    Mask="false">8080</Config>

  <!-- Photos directory — point this at your photo share -->
  <Config
    Name="Photos"
    Target="/mnt/photos"
    Default="/mnt/user/photos"
    Mode="rw"
    Description="Path to your photos share (contains source and dest sub-folders)"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/photos</Config>

  <!-- External / unallocated disks (requires Unassigned Devices plugin)
       Mount propagation is handled via ExtraParams above for rslave support.
       This path mapping remains as a fallback / documentation reference. -->
  <Config
    Name="External/Unallocated Disks"
    Target="/mnt/disks"
    Default="/mnt/disks"
    Mode="rw,rslave"
    Description="Mount unassigned/external drives so SnapSort can read from USB, SATA, or NVMe drives not in the array. Uses rslave propagation so hot-plugged drives appear automatically."
    Type="Path"
    Display="always"
    Required="false"
    Mask="false">/mnt/disks</Config>

  <!-- User shares (optional — gives access to all Unraid shares) -->
  <Config
    Name="User Shares"
    Target="/mnt/user"
    Default="/mnt/user"
    Mode="ro"
    Description="Mount Unraid user shares so SnapSort can browse files from any share (read-only by default)"
    Type="Path"
    Display="advanced"
    Required="false"
    Mask="false">/mnt/user</Config>

  <!-- SQLite database persistence -->
  <Config
    Name="App Data"
    Target="/app/backend/data"
    Default="/mnt/user/appdata/snapsort"
    Mode="rw"
    Description="Path to store the SnapSort database and config"
    Type="Path"
    Display="always"
    Required="true"
    Mask="false">/mnt/user/appdata/snapsort</Config>

  <!-- Environment -->
  <Config
    Name="NODE_ENV"
    Target="NODE_ENV"
    Default="production"
    Mode=""
    Description="Node environment (leave as production)"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">production</Config>

  <Config
    Name="PORT"
    Target="PORT"
    Default="4000"
    Mode=""
    Description="Internal port (should match Target of WebUI Port above)"
    Type="Variable"
    Display="advanced"
    Required="false"
    Mask="false">4000</Config>
</Container>
